# my.telegram.org dan olingan (shaxsiy akkauntingiz uchun)
API_ID=12345678
API_HASH=replace_with_real_api_hash

# BotFather dan olingan (yangi bot uchun)
BOT_TOKEN=1234567890:replace_with_real_bot_token

# aistudio.google.com/apikey dan olingan
GEMINI_API_KEY=AIzaSy_replace_with_real_key

# Guruh nomi (Telethon shu nom orqali topadi)
GROUP_NAME=O'sish nuqtasi

# Faqat ruxsat etilgan foydalanuvchilar (Telegram user ID, vergul bilan)
# Bo'sh qoldirsa - HAMMAGA ochiq (test uchun)
ALLOWED_USER_IDS=

# Telethon sessiya fayl nomi
SESSION_NAME=extractor

# Indekslangan chunklarning qaysi top-K si Gemini'ga yuboriladi
TOP_K=10

# Fayllar
OUTPUT_FILE=messages.json
INPUT_FILE=messages.json
